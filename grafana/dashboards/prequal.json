{
  "title": "Prequal Load Balancer",
  "uid": "prequal-main",
  "version": 1,
  "schemaVersion": 38,
  "refresh": "5s",
  "time": { "from": "now-5m", "to": "now" },
  "panels": [

    {
      "id": 1,
      "title": "Request Latency — p50 / p99 / p99.9",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 0, "w": 12, "h": 8 },
      "targets": [
        {
          "expr": "histogram_quantile(0.50, sum(rate(prequal_lb_request_latency_ms_bucket[30s])) by (le))",
          "legendFormat": "p50"
        },
        {
          "expr": "histogram_quantile(0.99, sum(rate(prequal_lb_request_latency_ms_bucket[30s])) by (le))",
          "legendFormat": "p99"
        },
        {
          "expr": "histogram_quantile(0.999, sum(rate(prequal_lb_request_latency_ms_bucket[30s])) by (le))",
          "legendFormat": "p99.9"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "ms",
          "color": { "mode": "palette-classic" }
        }
      }
    },

    {
      "id": 2,
      "title": "Requests per Second",
      "type": "timeseries",
      "gridPos": { "x": 12, "y": 0, "w": 12, "h": 8 },
      "targets": [
        {
          "expr": "sum(rate(prequal_lb_requests_total[30s]))",
          "legendFormat": "total rps"
        },
        {
          "expr": "sum(rate(prequal_lb_errors_total[30s]))",
          "legendFormat": "error rps"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "color": { "mode": "palette-classic" }
        }
      }
    },

    {
      "id": 3,
      "title": "RIF per Backend",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 8, "w": 12, "h": 8 },
      "targets": [
        {
          "expr": "prequal_backend_rif",
          "legendFormat": "{{ backend }}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "color": { "mode": "palette-classic" }
        }
      }
    },

    {
      "id": 4,
      "title": "Routing Distribution",
      "type": "timeseries",
      "gridPos": { "x": 12, "y": 8, "w": 12, "h": 8 },
      "targets": [
        {
          "expr": "sum(rate(prequal_backend_routings_total[30s])) by (backend)",
          "legendFormat": "{{ backend }}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "color": { "mode": "palette-classic" }
        }
      }
    },

    {
      "id": 5,
      "title": "Latency Estimate per Backend",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 16, "w": 12, "h": 8 },
      "targets": [
        {
          "expr": "prequal_backend_latency_est_ms",
          "legendFormat": "{{ backend }}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "ms",
          "color": { "mode": "palette-classic" }
        }
      }
    },

    {
      "id": 6,
      "title": "Backend Health",
      "type": "timeseries",
      "gridPos": { "x": 12, "y": 16, "w": 12, "h": 8 },
      "targets": [
        {
          "expr": "prequal_backend_healthy",
          "legendFormat": "{{ backend }}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "min": 0,
          "max": 1,
          "color": { "mode": "palette-classic" }
        }
      }
    },

    {
      "id": 7,
      "title": "Probe Pool Size",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 24, "w": 12, "h": 8 },
      "targets": [
        {
          "expr": "prequal_pool_size",
          "legendFormat": "pool size"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "color": { "mode": "palette-classic" }
        }
      }
    },

    {
      "id": 8,
      "title": "Pool Removals by Reason",
      "type": "timeseries",
      "gridPos": { "x": 12, "y": 24, "w": 12, "h": 8 },
      "targets": [
        {
          "expr": "sum(rate(prequal_pool_removals_total[30s])) by (reason)",
          "legendFormat": "{{ reason }}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "color": { "mode": "palette-classic" }
        }
      }
    }

  ]
}